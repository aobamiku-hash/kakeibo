rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ユーザーと世帯の紐付け ──
    match /userHouseholds/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['householdId'])
        && request.resource.data.householdId is string
        && exists(/databases/$(database)/documents/households/$(request.resource.data.householdId))
        && request.auth.uid in get(/databases/$(database)/documents/households/$(request.resource.data.householdId)).data.members;
    }

    // ── 世帯 ──
    match /households/{householdId} {
      allow create: if false;
      // 読み取り: 現在のメンバーのみ
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['categories', 'memberNames']);

      // ── 支出 ──
      match /expenses/{expenseId} {
        function isMember() {
          return request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
        }
        allow read: if request.auth != null && isMember();
        allow delete: if request.auth != null && isMember();
        allow create, update: if request.auth != null && isMember()
          && request.resource.data.amount is int
          && (request.resource.data.amount > 0
            || (request.resource.data.categoryId == 'cat_2'
              && request.resource.data.amount == 0
              && request.resource.data.isSkipped == true))
          && request.resource.data.yearMonth is string
          && request.resource.data.yearMonth.matches('^[0-9]{4}-[0-9]{2}$');
      }

      // ── 精算 ──
      match /settlements/{yearMonth} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }

      // ── 伝言板 ──
      match /messages/{messageId} {
        function isMember() {
          return request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
        }
        allow read, create: if request.auth != null && isMember();
        allow update: if request.auth != null && isMember();
        allow delete: if request.auth != null && isMember()
          && resource.data.createdBy == request.auth.uid;
      }

      // ── 旅行カウントダウン ──
      match /trips/{tripId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }
    }
  }
}
